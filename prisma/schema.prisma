// prisma/schema.prisma

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?   // hashed, nullable for OAuth
  image         String?
  plan          Plan      @default(FREE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Stripe billing
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?

  // Relations
  accounts      Account[]
  sessions      Session[]
  scans         SystemScan[]
  breachChecks  BreachCheck[]
  alerts        Alert[]
  monitoredEmails MonitoredEmail[]
  apiKey        ApiKey?
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id   @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemScan {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          ScanStatus  @default(PENDING)
  platform        String      // "linux" | "darwin" | "win32"
  osName          String?
  osVersion       String?
  kernelVersion   String?
  hostname        String?
  
  // Scores
  overallScore    Int?        // 0-100
  networkScore    Int?
  processScore    Int?
  softwareScore   Int?
  permissionScore Int?
  
  // Results (JSON blobs)
  openPorts       Json?       // [{port, service, state, risk}]
  runningProcesses Json?      // [{pid, name, cpu, memory, risk}]
  installedSoftware Json?     // [{name, version, cves}]
  permissionIssues Json?      // [{path, issue, severity}]
  networkInterfaces Json?     // [{name, address, type}]
  vulnerabilities  Json?      // [{id, title, severity, cvss, recommendation}]
  
  agentVersion    String?
  scanDuration    Int?        // ms
  createdAt       DateTime    @default(now())
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model BreachCheck {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  email       String
  breachCount Int      @default(0)
  breaches    Json?    // [{name, domain, date, dataClasses, severity}]
  
  checkedAt   DateTime @default(now())
}

model MonitoredEmail {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  email       String
  isVerified  Boolean   @default(false)
  lastChecked DateTime?
  breachCount Int       @default(0)
  breaches    Json?     // [{name, domain, breachDate, dataClasses}]
  alertOn     Boolean   @default(true)

  addedAt     DateTime  @default(now())
  @@unique([userId, email])
}

model Alert {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        AlertType
  severity    Severity
  title       String
  description String
  isRead      Boolean     @default(false)
  metadata    Json?
  
  createdAt   DateTime    @default(now())
}

enum AlertType {
  NEW_BREACH
  SYSTEM_VULNERABILITY
  PASSWORD_EXPOSED
  PHISHING_DETECTED
  SSL_EXPIRING
  SUSPICIOUS_PROCESS
}

enum Severity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  key       String   @unique
  name      String   @default("XtraShield Agent Key")
  lastUsed  DateTime?
  createdAt DateTime @default(now())
}
